{
  "compilerOptions": {
    "target": "ES2020",
    "checkJs": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "useUnknownInCatchVariables": false
  },
  "typeAcquisition": {
    "include": ["google-apps-script"]
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "**/node_modules/*"]
}
